# Baza i aplikacija
DATABASE_URI=postgresql://postgres:password@localhost:5432/flowapp
JWT_SECRET=replace-with-a-long-random-secret
PORT=5000
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# Izvor podataka za korisnički Loyalty portal: local, external ili demo
LOYALTY_PORTAL_SOURCE=local
LOYALTY_DEMO_MODE=false

# Vanjski dobavljač API-ja koristi se kada je LOYALTY_PORTAL_SOURCE=external
# LOYALTY_EXTERNAL_API_URL=https://loyalty.example.com/api/customer-summary
# LOYALTY_EXTERNAL_API_KEY=replace-with-production-api-key
# LOYALTY_EXTERNAL_API_TIMEOUT_MS=10000
