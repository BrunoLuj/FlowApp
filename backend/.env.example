# Baza i aplikacija
DATABASE_URI=postgresql://postgres:password@localhost:5432/flowapp
JWT_SECRET=replace-with-a-long-random-secret
PORT=5000
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# Lokalni Loyalty demo bez vanjskog API-ja
LOYALTY_DEMO_MODE=true

# Produkcija: isključiti demo i unijeti stvarne podatke dobavljača API-ja
# LOYALTY_DEMO_MODE=false
# LOYALTY_EXTERNAL_API_URL=https://loyalty.example.com/api/customer-summary
# LOYALTY_EXTERNAL_API_KEY=replace-with-production-api-key
# LOYALTY_EXTERNAL_API_TIMEOUT_MS=10000
